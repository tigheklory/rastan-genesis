    "desc":"Finish Current Sub-Round Now!",
    "script":{
      "on":" temp0=maincpup:readv_u8(0x10d243)  temp1=0x02  if (temp0 == 0x89) then temp2=0x89  temp1=0x01 end if (temp0 >= 0x83) and (temp0 < 0x89) then temp2=0x89 end if (temp0 >= 0x73) and (temp0 < 0x83) then temp2=0x83 end if (temp0 == 0x72) then temp2=0x73  temp1=0x01 end if (temp0 >= 0x6c) and (temp0 < 0x72) then temp2=0x72 end if (temp0 >= 0x5c) and (temp0 < 0x6c) then temp2=0x6c end if (temp0 == 0x5b) then temp2=0x5c  temp1=0x01 end if (temp0 >= 0x55) and (temp0 < 0x5b) then temp2=0x5b end if (temp0 >= 0x45) and (temp0 < 0x55) then temp2=0x55 end if (temp0 == 0x44) then temp2=0x45  temp1=0x01 end if (temp0 >= 0x3e) and (temp0 < 0x44) then temp2=0x44 end if (temp0 >= 0x2e) and (temp0 < 0x3f) then temp2=0x3f end if (temp0 == 0x2d) then temp2=0x2e  temp1=0x01 end if (temp0 >= 0x27) and (temp0 < 0x2d) then temp2=0x2d end if (temp0 >= 0x17) and (temp0 < 0x27) then temp2=0x27 end if (temp0 == 0x16) then temp2=0x17  temp1=0x01 end if (temp0 >= 0x10) and (temp0 < 0x16) then temp2=0x16 end if (temp0 >= 0x00) and (temp0 < 0x10) then temp2=0x10 end maincpup:writev_u8(0x10d243,temp2)  if (temp1 == 0x02) then maincpup:writev_u8(0x10c047,0x01) end if (temp1 == 0x01) then maincpup:writev_u16(0x10c708,0x0000)  maincpup:writev_u16(0x10c688,0x0000) end if (temp1 == 0x02) then maincpup:writev_u8(0x10c005,0x02) end maincpup:writev_u8(0x10c104,0x01)  if (temp1 == 0x02) then maincpup:writev_u8(0x10c003,0x02) end"
    },
