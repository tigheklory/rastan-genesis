  "version": 1,
  "scope": "startup_title_frontend",
  "description": "Declarative remap rules for the current Rastan boot/title/front-end bring-up path.",
  "policy": {
    "current_copy_mode": "whole_maincpu_relocated",
    "target_copy_mode": "whole_maincpu_relocated",
    "planned_arcade_rom_base": "0x000200",
    "launcher_reserved_rom_end_exclusive": "0x200000",
    "execute_from_relocated_base": true,
    "keep_identity_overlays_for_bringup": false,
    "normal_handoff": "one_way_after_launcher",
    "notes": [
      "Active build carries the entire maincpu at a relocated base and executes startup/frontend from that relocated base.",
      "Legacy identity overlays are disabled; translated execution is from relocated blocks only.",
      "Test mode remains on the preview/debug path until the real board test screen is running."
    ]
  },
  "whole_maincpu_copy": {
    "enabled": true,
    "source_start": "0x000000",
    "source_end_exclusive": "0x060000",
    "dest_start": "0x000200"
  },
